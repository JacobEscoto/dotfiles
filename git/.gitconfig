[user]
  name  = JacobEscoto
  email = djacobescotoz@gmail.com

[init]
  defaultBranch = main

[core]
  autocrlf = input
  whitespace = trailing-space,space-before-tab

[url "git@github.com:"]
  insteadOf = gh:

[credential "https://github.com"]
  helper =
  helper = !/home/linuxbrew/.linuxbrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
  helper =
  helper = !/home/linuxbrew/.linuxbrew/bin/gh auth git-credential
